# Site URL (used for SEO metadata and absolute URLs)
# In production (e.g. Railway), set to https://piratemaxx.com
NEXT_PUBLIC_SITE_URL=https://piratemaxx.com

# TikTok live indicator. Set TIKTOK_LIVE=true when you're live, then restart the app (no redeploy).
# The "LIVE on TikTok" badge appears on the homepage and navbar and links to your TikTok.
# TIKTOK_LIVE=true

# CDN for logos and images (optional)
# When set, getCdnUrl() and CdnImage use this base. Examples:
#   Cloudinary: https://res.cloudinary.com/your-cloud/image/upload
#   Custom:     https://cdn.piratemaxx.com
#   imgix:      https://your-subdomain.imgix.net
# Leave unset to serve images from /public (e.g. /images/logo.png)
# NEXT_PUBLIC_CDN_URL=https://cdn.piratemaxx.com

# Contact form → email (Resend)
# 1. Sign up at https://resend.com and get an API key.
# 2. Set CONTACT_EMAIL to the address where you want to receive inquiries (e.g. you@piratemaxx.com).
# 3. On the free tier you can send from onboarding@resend.dev only to your Resend account email;
#    to use your own domain (e.g. contact@piratemaxx.com), verify the domain in Resend and set RESEND_FROM_EMAIL.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=you@example.com
# RESEND_FROM_EMAIL=Contact <contact@piratemaxx.com>   # optional; default is onboarding@resend.dev

# Contact form -> GoHighLevel (GHL) CRM (client-first funnel)
# Recommended: set GHL_WEBHOOK_URL and trigger a workflow in your subaccount.
# Alternative: direct API mode with GHL_API_KEY + GHL_LOCATION_ID.
# GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
# GHL_API_KEY=pit_xxxxxxxxxxxx
# GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxx
# Optional API version header override (default in code: 2021-07-28)
# GHL_API_VERSION=2021-07-28
#
# Optional opportunity creation (direct API mode only):
# GHL_PIPELINE_ID=xxxxxxxxxxxxxxxxxxxx
# GHL_STAGE_ID=xxxxxxxxxxxxxxxxxxxx          # default stage for client leads
# GHL_QUOTE_STAGE_ID=xxxxxxxxxxxxxxxxxxxx    # optional stage used for quote-like inquiries
# Optional default opportunity values:
# GHL_CLIENT_MONETARY_VALUE=500
# GHL_QUOTE_MONETARY_VALUE=1000

# Public GHL funnels (optional; shown on /links page)
# NEXT_PUBLIC_GHL_CLIENT_FUNNEL_URL=https://your-subdomain.leadconnectorhq.com/...
# NEXT_PUBLIC_GHL_QUOTE_FUNNEL_URL=https://your-subdomain.leadconnectorhq.com/...

# Admin portfolio editor (/admin/portfolio)
# ADMIN_JWT_SECRET must be 32+ random characters (used to sign the session cookie).
# ADMIN_PORTFOLIO_PASSWORD is the login password for /admin/login.
# ADMIN_JWT_SECRET=your-32-plus-character-secret-here
# ADMIN_PORTFOLIO_PASSWORD=your-secure-password
#
# Production: store dynamic portfolio items in Upstash Redis (free tier works).
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
# Local dev: without Redis, items save to data/portfolio-user.json (gitignored).
